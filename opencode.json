{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "stripe": {
      "type": "local",
      "command": ["npx", "-y", "@stripe/mcp", "--api-key", "{env:STRIPE_SECRET_KEY}"]
    },
    "resend": {
      "type": "local",
      "command": ["bash", "-c", "export $(grep RESEND_API_KEY .env | xargs) && exec npx -y resend-mcp"]
    },
    "cloudflare": {
      "type": "local",
      "command": ["npx", "-y", "@cloudflare/mcp-server-cloudflare", "run", "cae4a54688a0a4c53bda4bd62eb37c35"],
      "env": {
        "CLOUDFLARE_API_TOKEN": "{env:CLOUDFLARE_API_TOKEN}"
      }
    },
    "supabase": {
      "type": "local",
      "command": ["npx", "-y", "@supabase/mcp-server-supabase"],
      "env": {
        "SUPABASE_URL": "{env:NEXT_PUBLIC_SUPABASE_URL}",
        "SUPABASE_SERVICE_ROLE_KEY": "{env:SUPABASE_SERVICE_ROLE_KEY}",
        "SUPABASE_ANON_KEY": "{env:NEXT_PUBLIC_SUPABASE_ANON_KEY}"
      }
    },
    "vercel": {
      "type": "local",
      "command": ["npx", "-y", "@nick-keller/vercel-mcp"],
      "env": {
        "VERCEL_TOKEN": "{env:VERCEL_TOKEN}",
        "VERCEL_TEAM_ID": "{env:VERCEL_TEAM_ID}"
      }
    }
  }
}
