{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "stripe": {
      "type": "local",
      "command": ["npx", "-y", "@stripe/mcp", "--api-key", "{env:STRIPE_SECRET_KEY}"]
    },
    "resend": {
      "type": "local",
      "command": ["bash", "-c", "export $(grep RESEND_API_KEY .env | xargs) && exec npx -y resend-mcp"]
    },
    "aws": {
      "type": "local",
      "command": ["uvx", "mcp-proxy-for-aws@1.6.3", "https://aws-mcp.us-east-1.api.aws/mcp", "--metadata", "AWS_REGION=ap-southeast-2", "--profile", "mcp-server"],
      "timeout": 100000
    },
    "cloudflare": {
      "type": "local",
      "command": ["npx", "-y", "@cloudflare/mcp-server-cloudflare", "run", "cae4a54688a0a4c53bda4bd62eb37c35"],
      "env": {
        "CLOUDFLARE_API_TOKEN": "{env:CLOUDFLARE_API_TOKEN}"
      }
    },
    "terraform": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "hashicorp/terraform-mcp-server:latest"]
    },
    "neon": {
      "type": "local",
      "command": ["npx", "-y", "@neondatabase/mcp-server-neon", "start", "{env:NEON_API_KEY}"]
    }
  }
}
