# ── How env vars work in this project ────────────────────────────────────────
# Secrets are stored in AWS Secrets Manager and loaded from .env.local
# (gitignored). Two secrets to dump:
#
#   1. Staging app vars:
#      aws secretsmanager get-secret-value \
#        --secret-id startline/staging/app \
#        --region ap-southeast-2 \
#        --query SecretString --output text | \
#        jq -r 'to_entries[] | "\(.key)=\(.value)"'
#
#   2. CI bootstrap (local-dev keys like RESEND_API_KEY, STRIPE_SECRET_KEY):
#      aws secretsmanager get-secret-value \
#        --secret-id startline/ci-bootstrap \
#        --region ap-southeast-2 \
#        --query SecretString --output text | \
#        jq -r 'to_entries[] | "\(.key)=\(.value)"'
#
#   Combine both into .env.local in the main checkout, then copy to each worktree:
#      cp /path/to/main/checkout/.env.local .
#
#   Override DATABASE_URL for local Docker:
#      DATABASE_URL=postgresql://postgres:postgres@localhost:5432/startline?schema=public
#
# ── Local-only constants ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/startline?schema=public"
SMTP_HOST="localhost"
SMTP_PORT="1025"
