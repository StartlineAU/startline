# ── How env vars work in this project ────────────────────────────────────────
# Secrets are stored in AWS Secrets Manager (startline/{env}/app) and loaded
# from .env.local (gitignored). To set up:
#
#   1. Dump the staging secret to .env.local in the main checkout:
#      aws secretsmanager get-secret-value \
#        --secret-id startline/staging/app \
#        --region ap-southeast-2 \
#        --query SecretString --output text | \
#        jq -r 'to_entries[] | "\(.key)=\(.value)"' \
#        > /path/to/main/checkout/.env.local
#
#   2. Copy into each new worktree:
#      cp /path/to/main/checkout/.env.local .
#
#   3. Override DATABASE_URL for local Docker:
#      DATABASE_URL=postgresql://postgres:postgres@localhost:5432/startline?schema=public
#
# ── Local-only constants ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/startline?schema=public"
SMTP_HOST="localhost"
SMTP_PORT="1025"
