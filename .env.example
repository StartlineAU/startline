# ── Database ────────────────────────────────────────────────────────────────────
# Local dev: Docker PostgreSQL on port 5432
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/startline?schema=public"

# ── AWS / Cognito ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_AWS_REGION="ap-southeast-2"
NEXT_PUBLIC_COGNITO_USER_POOL_ID="<pool-id>"
NEXT_PUBLIC_COGNITO_CLIENT_ID="<app-client-id>"

# ── AWS S3 ──────────────────────────────────────────────────────────────────────
AWS_S3_BUCKET="startline-uploads-dev"
AWS_S3_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Email (Resend) ──────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# SMTP settings for Mailpit in local dev (docker-compose)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""

# ── Stripe (Connect) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Stripe Connect Express client ID (OAuth onboarding flow)
NEXT_PUBLIC_STRIPE_CONNECT_CLIENT_ID="ca_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Local dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook` to get the secret

# ── ABN Lookup ──────────────────────────────────────────────────────────────────
ABR_GUID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ── AI (Anthropic) ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Cloudflare ─────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN="cfat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Public URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
