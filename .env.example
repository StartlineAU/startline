# ── How env vars work ───────────────────────────────────────────────────────
# For local dev: set these in your shell or .envrc.
# In production: set in Vercel project settings + Supabase dashboard.
# In CI: set as GitHub Actions secrets.

# Database (local Docker Postgres or Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/startline?schema=public"

# Supabase (get from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Email (Resend)
RESEND_API_KEY="re_..."

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Local dev
SMTP_HOST="localhost"
SMTP_PORT="1025"
