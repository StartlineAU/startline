generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── Admin accounts (created on first Cognito login, must be in "Admins" group) ─
model Admin {
  id         String   @id @default(uuid())
  cognitoSub String   @unique
  email      String   @unique
  name       String?
  createdAt  DateTime @default(now())

  eventReviews Event[]        @relation("EventReviewedBy")
  auditLogs    AdminAuditLog[]

  @@map("admins")
}

// ─── Admin audit log ─────────────────────────────────────────────────────────
model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      Admin    @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
  @@map("admin_audit_logs")
}

// ─── Organiser accounts ───────────────────────────────────────────────────────
// An organiser profile is always linked to a User (1:1). The User's auth
// credentials are used; the organiser record holds business-specific fields.
model Organiser {
  id         String          @id @default(uuid())
  userId String          @unique
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String          @unique
  verified   Boolean         @default(false)
  status     OrganiserStatus @default(APPROVED)

  // Profile — filled during onboarding, editable afterwards
  orgName      String?
  contactName  String?
  contactEmail String?
  phone        String?
  abn          String?
  website      String?
  instagram    String?
  facebook     String?
  bio            String?
  logoUrl        String?
  logoPosition   String?  @default("50% 50%")
  coverImageUrl  String?
  coverPosition  String?  @default("50% 50%")
  photos         String[]

  // Legal & compliance — required for ATO SERR reporting (ToS §3.2, Privacy Policy §2.1)
  legalName String?
  // Insurance self-declaration only — no documents collected (ToS §5.3, Privacy Policy §4.4)
  insuranceDeclared Boolean @default(false)
  // Date of birth (ISO 8601 yyyy-mm-dd) — used for identity verification and ATO SERR reporting.
  // Not required for organisers who only list external-link events.
  dob String?

  // Stripe Express Connect — Startline stores only the account reference ID.
  // Bank account details (BSB + account number) are collected and held by Stripe directly (ToS §3.3, Privacy Policy §4.2).
  stripeAccountId          String?  @unique
  stripeOnboardingComplete Boolean  @default(false)

  events        Event[]
  reviews       Review[]
  announcements Announcement[]
  notifications Notification[]
  registrations Registration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("organisers")
}

enum OrganiserStatus {
  APPROVED
  SUSPENDED
}

// ─── Event listings ───────────────────────────────────────────────────────────
model Event {
  id          String      @id @default(uuid())
  organiser   Organiser   @relation(fields: [organiserId], references: [id])
  organiserId String
  status      EventStatus @default(DRAFT)

  // Step 1 — basics
  title       String
  discipline  String
  tagline     String?
  description String?

  // Step 2 — date & location
  eventDate String
  endDate   String? // optional multi-day end (ISO yyyy-mm-dd)
  startTime String
  endTime   String
  venue     String
  address   String?
  city      String
  state     String

  // Step 3 — format & categories
  format     String
  level      String
  categories Json
  cap        Int?
  minAge     Int    @default(16)

  // Step 4 — tickets
  waves             Json
  inclusions        String?
  extras            String?
  activations       String?
  refundPolicy      String?
  registrationType  String  @default("startline")
  feeStructure      String  @default("athlete")

  // Step 5 — media & logistics
  coverImageUrl     String?
  photos            String[]
  registrationUrl   String?
  bagDrop           String?
  parking           String?
  accessibilityInfo String?
  additionalNotes   String?

  // Admin review
  adminNotes      String?
  rejectionReason String?
  reviewedById    String?
  reviewedBy      Admin?    @relation("EventReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?

  isPinned      Boolean        @default(false)
  reviews       Review[]
  announcements Announcement[]
  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("events")
}

enum EventStatus {
  DRAFT    // saved, not submitted
  PENDING  // submitted — awaiting admin review
  APPROVED // live on the platform
  REJECTED // admin denied
  ARCHIVED // organiser archived
}

// ─── Athlete reviews ──────────────────────────────────────────────────────────
model Review {
  id          String    @id @default(uuid())
  organiserId String
  organiser   Organiser @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  eventId     String?
  event       Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventTitle  String?

  // Ratings 1–5
  overallRating       Int
  atmosphereRating Int?
  organisationRating  Int?
  experienceRating    Int?

  title        String
  body         String
  reviewerName String

  isVerified  Boolean  @default(false)
  isPublished Boolean  @default(true)

  createdAt DateTime @default(now())

  @@map("reviews")
}

// ─── Organiser notifications ──────────────────────────────────────────────────
model Notification {
  id          String           @id @default(uuid())
  organiserId String
  organiser   Organiser        @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  body        String
  eventId     String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@map("notifications")
}

enum NotificationType {
  EVENT_APPROVED
  EVENT_REJECTED
  NEW_REGISTRATION
}

// ─── Organiser announcements (per-event) ─────────────────────────────────────
model Announcement {
  id          String    @id @default(uuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organiserId String
  organiser   Organiser @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  title       String
  body        String
  createdAt   DateTime  @default(now())

  @@map("announcements")
}

// ─── Athlete registrations ────────────────────────────────────────────────────
// One row per athlete entry into an event. organiserId is denormalised from the
// event so organisers can query their entire registrant base efficiently.
model Registration {
  id          String    @id @default(uuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organiserId String
  organiser   Organiser @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  userId String?
  user   User? @relation(fields: [userId], references: [id])

  athleteName  String
  athleteEmail String
  firstName    String?
  lastName     String?
  dateOfBirth  String? // ISO yyyy-mm-dd
  gender       String?
  mobile       String?
  emergencyContactName  String?
  emergencyContactPhone String?
  medicalNotes          String?
  waiverAccepted        Boolean @default(false)
  category     String?
  waveLabel    String?

  // Money is stored in integer cents (AUD) to avoid float rounding.
  amountCents      Int @default(0) // ticket price paid by the athlete
  platformFeeCents Int @default(0) // Startline fee (3% + $1) on this entry
  feeStructure     String @default("athlete") // "athlete" | "organiser"

  status                RegistrationStatus @default(CONFIRMED)
  stripePaymentIntentId String?

  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([organiserId])
  @@index([stripePaymentIntentId])
  @@map("registrations")
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
  REFUNDED
}

// ─── User accounts ────────────────────────────────────────────────────────────
// Every platform user has a User record. Organisers are users who also
// have an associated Organiser profile (1:1).
model User {
  id         String   @id @default(uuid())
  cognitoSub String?  @unique
  email      String   @unique
  name       String?  // full name
  username   String?  @unique // public handle, chosen during profile setup
  bio        String?
  profilePicUrl String?
  isPublic   Boolean  @default(true) // public profile visible to others
  isBanned   Boolean  @default(false)
  city       String? // for map centering on login
  state      String? // for map centering on login
  mfaEnabled   Boolean  @default(false)
  recoveryCodes String? // AES-256-GCM encrypted JSON array of 10 single-use recovery codes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organiser     Organiser?
  registrations Registration[]

  @@map("users")
}

model WaitlistSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist_subscribers")
}

model GuestEmailVerification {
  id         String    @id @default(uuid())
  email      String
  eventId    String
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  attempts   Int       @default(0)
  lastSentAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  @@index([email, eventId])
  @@map("guest_email_verifications")
}
