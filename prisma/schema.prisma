generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin accounts (created on first Cognito login, must be in "Admins" group) ─
model Admin {
  id         String   @id @default(uuid())
  cognitoSub String   @unique
  email      String   @unique
  name       String?
  createdAt  DateTime @default(now())

  eventReviews Event[] @relation("EventReviewedBy")
}

// ─── Organiser accounts ───────────────────────────────────────────────────────
model Organiser {
  id         String          @id @default(uuid())
  email      String          @unique
  cognitoSub String          @unique
  status     OrganiserStatus @default(APPROVED)

  // Profile — filled during onboarding, editable afterwards
  orgName      String?
  contactName  String?
  contactEmail String?
  phone        String?
  abn          String?
  website      String?
  instagram    String?
  facebook     String?
  bio          String?
  logoUrl      String?

  events    Event[]
  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrganiserStatus {
  APPROVED
  SUSPENDED
}

// ─── Event listings ───────────────────────────────────────────────────────────
model Event {
  id          String      @id @default(uuid())
  organiser   Organiser   @relation(fields: [organiserId], references: [id])
  organiserId String
  status      EventStatus @default(DRAFT)

  // Step 1 — basics
  title       String
  discipline  String
  tagline     String?
  description String?

  // Step 2 — date & location
  eventDate String
  endDate   String? // optional multi-day end (ISO yyyy-mm-dd)
  startTime String
  endTime   String
  venue     String
  address   String?
  city      String
  state     String

  // Step 3 — format & categories
  format     String
  level      String
  categories Json
  cap        Int?
  minAge     Int    @default(16)

  // Step 4 — tickets
  waves        Json
  inclusions   String?
  extras       String?
  activations  String?
  refundPolicy String?

  // Step 5 — media & logistics
  coverImageUrl     String?
  registrationUrl   String?
  bagDrop           String?
  parking           String?
  accessibilityInfo String?
  additionalNotes   String?

  // Admin review
  adminNotes      String?
  rejectionReason String?
  reviewedById    String?
  reviewedBy      Admin?    @relation("EventReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?

  isPinned Boolean @default(false)
  reviews  Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventStatus {
  DRAFT    // saved, not submitted
  PENDING  // submitted — awaiting admin review
  APPROVED // live on the platform
  REJECTED // admin denied
  ARCHIVED // organiser archived
}

// ─── Athlete reviews ──────────────────────────────────────────────────────────
model Review {
  id          String    @id @default(uuid())
  organiserId String
  organiser   Organiser @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  eventId     String?
  event       Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventTitle  String?

  // Ratings 1–5
  overallRating       Int
  communicationRating Int?
  organisationRating  Int?
  experienceRating    Int?

  title        String
  body         String
  reviewerName String

  isVerified  Boolean  @default(false)
  isPublished Boolean  @default(true)

  createdAt DateTime @default(now())
}
