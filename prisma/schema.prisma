generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Admin accounts (created on first Cognito login, must be in "Admins" group) ─
model Admin {
  id         String   @id @default(uuid())
  cognitoSub String   @unique
  email      String   @unique
  name       String?
  createdAt  DateTime @default(now())

  eventReviews Event[] @relation("EventReviewedBy")
}

// ─── Organiser accounts ───────────────────────────────────────────────────────
model Organiser {
  id         String          @id @default(uuid())
  email      String          @unique
  cognitoSub String          @unique
  status     OrganiserStatus @default(APPROVED)

  // Profile — filled during onboarding, editable afterwards
  orgName      String?
  contactName  String?
  contactEmail String?
  phone        String?
  abn          String?
  website      String?
  instagram    String?
  facebook     String?
  bio            String?
  logoUrl        String?
  logoPosition   String?  @default("50% 50%")
  coverImageUrl  String?
  coverPosition  String?  @default("50% 50%")
  photos         String[]

  // Legal & compliance — required for ATO SERR reporting (ToS §3.2, Privacy Policy §2.1)
  legalName String?
  // Insurance self-declaration only — no documents collected (ToS §5.3, Privacy Policy §4.4)
  insuranceDeclared Boolean @default(false)
  // Date of birth (ISO 8601 yyyy-mm-dd) — used for identity verification and ATO SERR reporting.
  // Not required for organisers who only list external-link events.
  dob String?

  // Stripe Express Connect — Startline stores only the account reference ID.
  // Bank account details (BSB + account number) are collected and held by Stripe directly (ToS §3.3, Privacy Policy §4.2).
  stripeAccountId          String?  @unique
  stripeOnboardingComplete Boolean  @default(false)

  events        Event[]
  reviews       Review[]
  announcements Announcement[]
  notifications Notification[]
  registrations Registration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum OrganiserStatus {
  APPROVED
  SUSPENDED
}

// ─── Event listings ───────────────────────────────────────────────────────────
model Event {
  id          String      @id @default(uuid())
  organiser   Organiser   @relation(fields: [organiserId], references: [id])
  organiserId String
  status      EventStatus @default(DRAFT)

  // Step 1 — basics
  title       String
  discipline  String
  tagline     String?
  description String?

  // Step 2 — date & location
  eventDate String
  endDate   String? // optional multi-day end (ISO yyyy-mm-dd)
  startTime String
  endTime   String
  venue     String
  address   String?
  city      String
  state     String

  // Step 3 — format & categories
  format     String
  level      String
  categories Json
  cap        Int?
  minAge     Int    @default(16)

  // Step 4 — tickets
  waves             Json
  inclusions        String?
  extras            String?
  activations       String?
  refundPolicy      String?
  registrationType  String  @default("startline")
  feeStructure      String  @default("athlete")

  // Step 5 — media & logistics
  coverImageUrl     String?
  registrationUrl   String?
  bagDrop           String?
  parking           String?
  accessibilityInfo String?
  additionalNotes   String?

  // Admin review
  adminNotes      String?
  rejectionReason String?
  reviewedById    String?
  reviewedBy      Admin?    @relation("EventReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?

  isPinned      Boolean        @default(false)
  reviews       Review[]
  announcements Announcement[]
  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventStatus {
  DRAFT    // saved, not submitted
  PENDING  // submitted — awaiting admin review
  APPROVED // live on the platform
  REJECTED // admin denied
  ARCHIVED // organiser archived
}

// ─── Athlete reviews ──────────────────────────────────────────────────────────
model Review {
  id          String    @id @default(uuid())
  organiserId String
  organiser   Organiser @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  eventId     String?
  event       Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventTitle  String?

  // Ratings 1–5
  overallRating       Int
  communicationRating Int?
  organisationRating  Int?
  experienceRating    Int?

  title        String
  body         String
  reviewerName String

  isVerified  Boolean  @default(false)
  isPublished Boolean  @default(true)

  createdAt DateTime @default(now())
}

// ─── Organiser notifications ──────────────────────────────────────────────────
model Notification {
  id          String           @id @default(uuid())
  organiserId String
  organiser   Organiser        @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  body        String
  eventId     String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
}

enum NotificationType {
  EVENT_APPROVED
  EVENT_REJECTED
  NEW_REGISTRATION
}

// ─── Organiser announcements (per-event) ─────────────────────────────────────
model Announcement {
  id          String    @id @default(uuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organiserId String
  organiser   Organiser @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  title       String
  body        String
  createdAt   DateTime  @default(now())
}

// ─── Athlete registrations ────────────────────────────────────────────────────
// One row per athlete entry into an event. organiserId is denormalised from the
// event so organisers can query their entire registrant base efficiently.
model Registration {
  id          String    @id @default(uuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organiserId String
  organiser   Organiser @relation(fields: [organiserId], references: [id], onDelete: Cascade)

  athleteName  String
  athleteEmail String
  category     String?
  waveLabel    String?

  // Money is stored in integer cents (AUD) to avoid float rounding.
  amountCents      Int @default(0) // ticket price paid by the athlete
  platformFeeCents Int @default(0) // Startline fee (3% + $1) on this entry
  feeStructure     String @default("athlete") // "athlete" | "organiser"

  status                RegistrationStatus @default(CONFIRMED)
  stripePaymentIntentId String?            @unique

  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([organiserId])
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
  REFUNDED
}

// ─── Athlete accounts ─────────────────────────────────────────────────────────
model Athlete {
  id         String   @id @default(uuid())
  cognitoSub String   @unique
  email      String   @unique
  name       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WaitlistSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist_subscribers")
}

model LegacyEvent {
  id              Int      @id @default(autoincrement())
  title           String
  description     String
  date            DateTime @db.Date
  time            String
  endTime         String?  @map("end_time")
  location        String
  city            String
  state           String
  type            String
  format          String
  level           String
  image           String
  registrationUrl String   @map("registration_url")
  organizer       String?
  distance        String?
  isOfficial      Boolean  @default(false) @map("is_official")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("events")
}
